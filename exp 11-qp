import pandas as pd
import numpy as np
df = pd.DataFrame(np.random.rand(10, 4), columns=[f'col{i}' for i in range(1, 5)])
for col in df.columns:
    df.loc[df.sample(frac=0.2).index, col] = np.nan
print("Original DataFrame with NaN values:")
display(df)
def highlight_nan(val):
    """Highlights NaN values in a DataFrame cell."""
    return 'background-color: yellow' if pd.isna(val) else ''
print("\nDataFrame with NaN values highlighted:")
display(df.style.applymap(highlight_nan))
